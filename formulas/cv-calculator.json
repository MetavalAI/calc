{
  "id": "cv-calculator",
  "name": "CV Calculator (Flow Coefficient)",
  "tag": "Flow Coefficient",
  "icon": "💧",
  "description": "Cv is defined as the flow of water at 60°F in gallons per minute at a pressure drop of 1 PSIG.",
  "formula": "Cv = Q<sub>L</sub> × √SG / √ΔP",
  "definitions": [
    { "symbol": "Q<sub>L</sub>", "label": "Flow Rate of Liquid" },
    { "symbol": "SG",             "label": "Specific Gravity" },
    { "symbol": "ΔP",             "label": "Differential Pressure" }
  ],
  "unitSystems": {
    "SI":       { "flow": "m3h",  "pressure": "bar" },
    "CGS":      { "flow": "m3h",  "pressure": "bar" },
    "Imperial": { "flow": "gpm",  "pressure": "psi" }
  },
  "inputs": [
    {
      "id": "flow", "label": "Flow Rate", "default": 45,
      "units": [
        { "value": "gpm",  "label": "GPM",    "toBase": "v => v",           "fromBase": "v => v"           },
        { "value": "m3h",  "label": "m³/hr",  "toBase": "v => v * 4.40286", "fromBase": "v => v / 4.40286" },
        { "value": "lpm",  "label": "L/min",  "toBase": "v => v * 0.264172","fromBase": "v => v / 0.264172"}
      ]
    },
    {
      "id": "sg", "label": "Specific Gravity", "default": 1,
      "units": [
        { "value": "sg", "label": "SG", "toBase": "v => v", "fromBase": "v => v" }
      ]
    },
    {
      "id": "pressure", "label": "Differential Pressure", "default": 0.8492,
      "units": [
        { "value": "psi",   "label": "PSI",     "toBase": "v => v",            "fromBase": "v => v"            },
        { "value": "bar",   "label": "BAR",     "toBase": "v => v * 14.50377", "fromBase": "v => v / 14.50377" },
        { "value": "kgcm2", "label": "Kg/cm²",  "toBase": "v => v * 14.2233",  "fromBase": "v => v / 14.2233"  },
        { "value": "kpa",   "label": "kPa",     "toBase": "v => v * 0.14504",  "fromBase": "v => v / 0.14504"  }
      ]
    }
  ],
  "calculate": {
    "steps": [
      "const q  = values.flow_unit.toBase(values.flow);",
      "const sg = values.sg;",
      "const dp = values.pressure_unit.toBase(values.pressure);",
      "if (q <= 0 || sg <= 0 || dp <= 0) return { results: [], derived: [] };",
      "const cv = q * Math.sqrt(sg) / Math.sqrt(dp);",
      "return { results: [{ label: 'Cv (Flow Coefficient)', value: cv.toFixed(4), unit: '—', highlight: true }], derived: [] };"
    ]
  }
}
